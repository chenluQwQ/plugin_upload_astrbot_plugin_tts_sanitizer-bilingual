{
  "enabled": {
    "description": "是否启用TTS文本过滤功能",
    "type": "bool",
    "default": true
  },
  "bilingual_tts": {
    "description": "双语TTS模式：开启后，TTS朗读翻译语言，显示文本保留中文。需要配置翻译API。",
    "type": "bool",
    "default": false
  },
  "tts_language": {
    "description": "TTS朗读语言",
    "type": "string",
    "default": "English",
    "hint": "例如：English, Japanese, Korean, French, Spanish, German 等"
  },
  "translate_api_base": {
    "description": "翻译API地址（OpenAI兼容格式）",
    "type": "string",
    "default": "",
    "hint": "例如：https://openrouter.ai/api/v1 或 https://api.openai.com/v1"
  },
  "translate_api_key": {
    "description": "翻译API密钥",
    "type": "string",
    "default": ""
  },
  "translate_model": {
    "description": "翻译使用的模型（建议用便宜的小模型）",
    "type": "string",
    "default": "gpt-4o-mini",
    "hint": "例如：gpt-4o-mini, google/gemini-2.0-flash-lite, deepseek/deepseek-chat 等"
  },
  "enable_speak_tool": {
    "description": "启用语音Tool：让模型可以主动发送语音消息。用户说"说一句话"、"念给我听"等时模型会自动调用。",
    "type": "bool",
    "default": false
  },
  "max_length": {
    "description": "最大朗读字数（超过此字数跳过朗读，0表示无限制）",
    "type": "int",
    "default": 200,
    "hint": "范围：0-1000"
  },
  "max_processing_length": {
    "description": "最大处理文本长度（超过此长度跳过过滤）",
    "type": "int",
    "default": 10000,
    "hint": "范围：1000-50000"
  },
  "remove_patterns": {
    "description": "正则过滤规则（匹配到的内容会被删除）",
    "type": "list",
    "items": { "type": "string" },
    "default": [
      "[（(][^（()]*[）)]",
      "[＞>][＿_][＜<]",
      "[＾^][＿_][＾^]",
      "[oO][＿_][oO]",
      "[xX][＿_][xX]",
      "[－-][＿_][－-]",
      "[★☆♪♫♬♩♡♥❤️💖💕💗💓💝💟💜💛💚💙🧡🤍🖤🤎💔❣️💋]",
      "[→←↑↓↖↗↘↙↔↕↺↻]"
    ]
  },
  "filter_words": {
    "description": "直接过滤的字符和词汇",
    "type": "list",
    "items": { "type": "string" },
    "default": [
      "ω", "Ω", "σ", "Σ", "ε", "д", "Д",
      "´", "`", "＝", "∀", "∇",
      "orz", "OTZ", "QAQ", "QWQ", "TAT", "TUT", "www"
    ]
  },
  "replacement_words": {
    "description": "替换词汇配置（格式：原词|替换词）",
    "type": "list",
    "items": { "type": "string" },
    "default": [
      "233|哈哈哈",
      "666|厉害",
      "999|很棒",
      "555|呜呜呜"
    ]
  },
  "max_repeat_count": {
    "description": "重复字符压缩（如设为2，哈哈哈哈→哈哈），0=关闭",
    "type": "int",
    "default": 2,
    "hint": "范围：0-5"
  },
  "tts_pause_markers": {
    "description": "为MiniMax TTS添加停顿标记（句号停2拍，逗号停1拍）",
    "type": "bool",
    "default": false
  },
  "debug_mode": {
    "description": "调试模式，在日志中显示详细过滤和翻译过程",
    "type": "bool",
    "default": false
  }
}
